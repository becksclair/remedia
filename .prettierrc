{
    "useTabs": true,
    "singleQuote": true,
    "semi": false,
    "trailingComma": "none",
    "printWidth": 120,
    "arrowParens": "avoid",
    "svelteAllowShorthand": true,
    "svelteBracketNewLine": false,
    "plugins": ["prettier-plugin-svelte"],
    "pluginSearchDirs": ["."],
    "overrides": [{ "files": "*.svelte", "options": { "parser": "svelte" } }]
}